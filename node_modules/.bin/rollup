#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/@rollup+wasm-node@4.60.2/node_modules/@rollup/wasm-node/node_modules:/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/@rollup+wasm-node@4.60.2/node_modules:/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/@rollup+wasm-node@4.60.2/node_modules/@rollup/wasm-node/node_modules:/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/@rollup+wasm-node@4.60.2/node_modules:/Users/zhengjianqiao/workspace/db-cookbook/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/@rollup+wasm-node@4.60.2/node_modules/@rollup/wasm-node/dist/bin/rollup" "$@"
else
  exec node  "$basedir/../.pnpm/@rollup+wasm-node@4.60.2/node_modules/@rollup/wasm-node/dist/bin/rollup" "$@"
fi
