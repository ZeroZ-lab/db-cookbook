{
  "name": "db-cookbook",
  "private": true,
  "type": "module",
  "scripts": {
    "site:generate": "node scripts/generate-site.mjs",
    "projects:generate-runbook": "node scripts/generate-project-runbook.mjs",
    "facts:generate-records": "node scripts/generate-fact-check-records.mjs",
    "verify": "node scripts/verify-book-structure.mjs && node scripts/verify-writing-contract.mjs && node scripts/verify-manuscript-depth.mjs && node scripts/verify-terminology.mjs && node scripts/verify-editorial-quality.mjs && node scripts/verify-status-language.mjs && node scripts/verify-sql-examples.mjs && node scripts/verify-project-workbench.mjs && node scripts/verify-fact-check-matrix.mjs && node scripts/verify-fact-check-closure.mjs && node scripts/verify-completion-audit.mjs",
    "book:verify": "node scripts/verify-book-structure.mjs",
    "writing:verify": "node scripts/verify-writing-contract.mjs",
    "depth:verify": "node scripts/verify-manuscript-depth.mjs",
    "terms:verify": "node scripts/verify-terminology.mjs",
    "editorial:verify": "node scripts/verify-editorial-quality.mjs",
    "status:verify": "node scripts/verify-status-language.mjs",
    "sql:verify": "node scripts/verify-sql-examples.mjs",
    "projects:verify": "node scripts/verify-project-workbench.mjs",
    "facts:verify": "node scripts/verify-fact-check-matrix.mjs",
    "facts:closure:verify": "node scripts/verify-fact-check-closure.mjs",
    "audit:verify": "node scripts/verify-completion-audit.mjs",
    "sql:run": "bash scripts/run-postgres-examples.sh",
    "docs:dev": "pnpm site:generate && vitepress dev site --host 0.0.0.0",
    "docs:build": "pnpm site:generate && vitepress build site",
    "docs:preview": "vitepress preview site --host 0.0.0.0"
  },
  "devDependencies": {
    "mermaid": "^11.4.1",
    "rollup": "npm:@rollup/wasm-node@4.60.2",
    "vitepress": "^1.6.4",
    "vue": "3.5.33"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "overrides": {
      "rollup@4.60.2": "npm:@rollup/wasm-node@4.60.2"
    }
  }
}
